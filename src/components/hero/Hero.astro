---
import { hero } from "../../lib/content";
import MeshBackground from "./MeshBackground";
import DashboardPreview from "./DashboardPreview.astro";
---

<section class="relative pt-32 md:pt-40 pb-16 md:pb-24 overflow-hidden">
  <MeshBackground client:load />

  <div class="container-page relative">
    <!-- Eyebrow -->
    <div class="flex justify-center mb-6 md:mb-8 reveal">
      <span class="eyebrow">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-300 animate-pulse-glow"></span>
        {hero.eyebrow}
      </span>
    </div>

    <!-- Headline -->
    <h1 class="reveal text-center mx-auto max-w-5xl text-5xl sm:text-6xl md:text-7xl lg:text-[88px] font-display font-semibold leading-[0.98] tracking-[-0.025em]">
      <span class="block">{hero.headline[0]}</span>
      <span class="block text-gradient mt-1 md:mt-2">{hero.headline[1]}</span>
    </h1>

    <!-- Sub -->
    <p class="reveal mx-auto mt-6 md:mt-8 max-w-2xl text-center text-lg md:text-xl text-slate-300 leading-[1.55]">
      {hero.subheadline}
    </p>

    <!-- CTAs -->
    <div class="reveal mt-8 md:mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={hero.primaryCta.href} class="btn-primary">
        {hero.primaryCta.label}
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4" />
        </svg>
      </a>
      <a href={hero.secondaryCta.href} class="btn-ghost">
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="4,3 13,8 4,13" fill="currentColor"/>
        </svg>
        {hero.secondaryCta.label}
      </a>
    </div>

    <p class="reveal mt-5 md:mt-6 text-center text-sm text-slate-500">
      {hero.trustLine}
    </p>

    <!-- Dashboard preview -->
    <div class="reveal mt-16 md:mt-24">
      <DashboardPreview />
    </div>
  </div>
</section>
