---
import { features } from "../../lib/content";
import BentoCard from "./BentoCard.astro";
---

<section id="features" class="section relative">
  <div class="container-page">
    <!-- Section header -->
    <div class="max-w-3xl mb-12 md:mb-16 reveal">
      <span class="eyebrow">
        <span class="w-1 h-1 rounded-full bg-cyan-300"></span>
        Features
      </span>
      <h2 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-display font-semibold tracking-[-0.022em] leading-[1.05]">
        One workspace.
        <br />
        <span class="text-gradient">Every AI capability.</span>
      </h2>
      <p class="mt-5 text-lg text-slate-300 leading-relaxed max-w-2xl">
        Lumen unifies the tools you'd otherwise stitch together — orchestration,
        knowledge, observability, and governance — into a single, fast interface.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      {features.map((f, i) => (
        <BentoCard
          title={f.title}
          description={f.description}
          icon={f.icon}
          span={f.span}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
