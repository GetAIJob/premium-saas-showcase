---
interface Props {
  title: string;
  description: string;
  icon: string;
  span?: string;
  index?: number;
}

const { title, description, icon, span = "", index = 0 } = Astro.props;
const isLarge = span.includes("col-span-2");
---

<article
  class={`reveal group relative glass rounded-2xl p-6 md:p-7 overflow-hidden transition-all duration-500 hover:border-white/[0.16] hover:-translate-y-1 ${span}`}
  style={`transition-delay: ${index * 60}ms;`}
>
  <!-- Glow on hover -->
  <div aria-hidden class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
    <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full bg-cyan-400/20 blur-3xl"></div>
    <div class="absolute -bottom-10 -left-10 w-40 h-40 rounded-full bg-indigo-500/20 blur-3xl"></div>
  </div>

  <!-- Visual -->
  <div class={`relative ${isLarge ? "h-56 md:h-64" : "h-32 md:h-36"} mb-5 md:mb-6 rounded-xl overflow-hidden bg-gradient-to-br from-white/[0.02] to-white/[0.005] border border-white/[0.04] flex items-center justify-center`}>
    {icon === "graph" && (
      <svg viewBox="0 0 280 160" class="w-full h-full text-cyan-300" fill="none" stroke="currentColor" stroke-width="1.2">
        <defs>
          <linearGradient id="edge-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#22D3EE" stop-opacity="0.0"/>
            <stop offset="50%" stop-color="#22D3EE" stop-opacity="0.6"/>
            <stop offset="100%" stop-color="#6366F1" stop-opacity="0.0"/>
          </linearGradient>
        </defs>
        <!-- edges -->
        <g stroke="url(#edge-grad)" stroke-width="1.5">
          <path d="M40 80 Q90 40 140 80" />
          <path d="M40 80 Q90 120 140 80" />
          <path d="M140 80 Q190 40 240 80" />
          <path d="M140 80 Q190 120 240 80" />
          <path d="M40 80 L240 80" stroke-dasharray="2 4" opacity="0.5"/>
        </g>
        <!-- nodes -->
        <g>
          <circle cx="40" cy="80" r="12" fill="#0B1026" stroke="#6366F1" stroke-width="1.6"/>
          <circle cx="40" cy="80" r="3" fill="#A78BFA"/>
          <circle cx="140" cy="80" r="14" fill="#0B1026" stroke="#22D3EE" stroke-width="1.8"/>
          <circle cx="140" cy="80" r="4" fill="#22D3EE">
            <animate attributeName="r" values="3;5;3" dur="2.4s" repeatCount="indefinite"/>
          </circle>
          <circle cx="240" cy="80" r="12" fill="#0B1026" stroke="#3B82F6" stroke-width="1.6"/>
          <circle cx="240" cy="80" r="3" fill="#93C5FD"/>
          <!-- secondary -->
          <circle cx="190" cy="40" r="8" fill="#0B1026" stroke="#A78BFA" stroke-width="1.4"/>
          <circle cx="190" cy="120" r="8" fill="#0B1026" stroke="#22D3EE" stroke-width="1.4"/>
          <circle cx="90" cy="40" r="8" fill="#0B1026" stroke="#22D3EE" stroke-width="1.4"/>
          <circle cx="90" cy="120" r="8" fill="#0B1026" stroke="#A78BFA" stroke-width="1.4"/>
        </g>
      </svg>
    )}

    {icon === "network" && (
      <svg viewBox="0 0 200 120" class="w-full h-full text-indigo-300" fill="none">
        <g opacity="0.7">
          {Array.from({ length: 18 }).map((_, i) => {
            const angle = (i / 18) * Math.PI * 2;
            const r = 36;
            const x = 100 + Math.cos(angle) * r;
            const y = 60 + Math.sin(angle) * r;
            return <line x1="100" y1="60" x2={x} y2={y} stroke="#6366F1" stroke-width="0.6" opacity="0.5"/>;
          })}
        </g>
        <circle cx="100" cy="60" r="6" fill="#22D3EE"/>
        {Array.from({ length: 18 }).map((_, i) => {
          const angle = (i / 18) * Math.PI * 2;
          const r = 36;
          const x = 100 + Math.cos(angle) * r;
          const y = 60 + Math.sin(angle) * r;
          return <circle cx={x} cy={y} r="1.8" fill="#A5B4FC"/>;
        })}
      </svg>
    )}

    {icon === "stepper" && (
      <svg viewBox="0 0 200 80" class="w-full h-full text-cyan-200" fill="none" stroke="currentColor">
        <line x1="20" y1="40" x2="180" y2="40" stroke="rgba(99,102,241,0.2)" stroke-width="2"/>
        <line x1="20" y1="40" x2="120" y2="40" stroke="url(#step-grad)" stroke-width="2"/>
        <defs>
          <linearGradient id="step-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#22D3EE"/>
            <stop offset="100%" stop-color="#6366F1"/>
          </linearGradient>
        </defs>
        <circle cx="20" cy="40" r="6" fill="#22D3EE"/>
        <circle cx="70" cy="40" r="6" fill="#22D3EE"/>
        <circle cx="120" cy="40" r="7" fill="#6366F1" stroke="#A5B4FC" stroke-width="1.5"/>
        <circle cx="170" cy="40" r="5" fill="none" stroke="#475569" stroke-width="1.5"/>
        <circle cx="120" cy="40" r="12" fill="none" stroke="#A5B4FC" stroke-width="0.8" opacity="0.4">
          <animate attributeName="r" values="10;16;10" dur="2s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.5;0;0.5" dur="2s" repeatCount="indefinite"/>
        </circle>
      </svg>
    )}

    {icon === "stack" && (
      <div class="flex items-center gap-3">
        {["Claude", "GPT-4", "Llama", "+12"].map((m) => (
          <span class="px-3 py-2 rounded-lg glass text-xs font-mono text-slate-300 border-white/[0.08]">
            {m}
          </span>
        ))}
      </div>
    )}

    {icon === "shield" && (
      <svg viewBox="0 0 80 80" class="w-20 h-20 text-cyan-300" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M40 8 L66 18 V42 C66 56 54 68 40 72 C26 68 14 56 14 42 V18 Z"
          fill="rgba(34,211,238,0.06)" stroke="#22D3EE"/>
        <path d="M28 40 L36 48 L52 32" stroke="#A5B4FC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}

    {icon === "cursors" && (
      <div class="flex gap-4">
        {[
          { color: "#22D3EE", name: "MA" },
          { color: "#A78BFA", name: "LC" },
          { color: "#6366F1", name: "PS" },
        ].map((c) => (
          <div class="flex flex-col items-center gap-1.5">
            <svg viewBox="0 0 24 24" width="20" height="20" fill={c.color}>
              <path d="M3 2 L3 19 L9 14 L13 22 L16 21 L12 13 L20 12 Z"/>
            </svg>
            <span class="px-2 py-0.5 rounded-full text-[10px] font-medium" style={`background:${c.color}26; color:${c.color}`}>{c.name}</span>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Text -->
  <h3 class="text-lg md:text-xl font-display font-semibold tracking-tight text-white">
    {title}
  </h3>
  <p class="mt-2 text-sm md:text-[15px] text-slate-400 leading-relaxed">
    {description}
  </p>
</article>
