---
import { testimonials } from "../../lib/content";
---

<section id="customers" class="section relative">
  <div class="container-page">
    <div class="text-center max-w-3xl mx-auto mb-14 md:mb-16 reveal">
      <span class="eyebrow">
        <span class="w-1 h-1 rounded-full bg-cyan-300"></span>
        Customers
      </span>
      <h2 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-display font-semibold tracking-[-0.022em] leading-[1.05]">
        Loved by teams who <span class="text-gradient">ship fast</span>.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
      {testimonials.map((t, i) => (
        <figure
          class="reveal glass rounded-2xl p-7 md:p-8 hover:border-white/[0.14] transition-colors duration-500"
          style={`transition-delay: ${i * 100}ms;`}
        >
          <svg class="w-7 h-7 text-indigo-300/40 mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 7H5a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v3c0 1.1-.9 2-2 2H4v2h1c2.21 0 4-1.79 4-4V9a2 2 0 0 0 0-2zm10 0h-4a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2v3c0 1.1-.9 2-2 2h-1v2h1c2.21 0 4-1.79 4-4V9a2 2 0 0 0 0-2z"/>
          </svg>
          <blockquote class="text-base md:text-lg text-slate-200 leading-[1.55] tracking-[-0.005em]">
            “{t.quote}”
          </blockquote>
          <figcaption class="mt-6 flex items-center gap-3 pt-5 border-t border-white/[0.06]">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gradient-brand text-[#050816] text-xs font-semibold tracking-wider">
              {t.initials}
            </span>
            <div class="text-sm">
              <div class="font-medium text-white">{t.name}</div>
              <div class="text-slate-500">{t.role} · {t.company}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
